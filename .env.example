# ---------------------------------------------------------------
# TimescaleDB
# ---------------------------------------------------------------
POSTGRES_USER=weather_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=weather_db
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432

# ---------------------------------------------------------------
# Airflow
# ---------------------------------------------------------------
AIRFLOW_FERNET_KEY=your_fernet_key_here   # generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=your_admin_password
AIRFLOW_DB=airflow_metadata
AIRFLOW_ADMIN_EMAIL=admin@example.com

# ---------------------------------------------------------------
# Open-Meteo API base URLs  (free, no key required)
# ---------------------------------------------------------------
WEATHER_API_URL=https://archive-api.open-meteo.com/v1/archive
AQI_API_URL=https://air-quality-api.open-meteo.com/v1/air-quality

# ---------------------------------------------------------------
# Pipeline connection string (used inside Airflow tasks)
# ---------------------------------------------------------------
PIPELINE_DB_URL=postgresql://weather_user:your_secure_password@localhost:5433/weather_db

# ---------------------------------------------------------------
# LLM provider — Groq (free tier available at console.groq.com)
# ---------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here

# Optional — OpenRouter fallback
# OPENROUTER_API_KEY=your_openrouter_key_here
